#include "common.keymap"

#define UF_RESET bootloader_reset 0 0
#define UF_BT1 device_bt1 0 0
#define UF_BT2 device_bt2 0 1
#define UF_BT3 device_bt3 0 2

/ {
    keymap {
        compatible = "zmk,keymap";
        
        default_layer {

            bindings = <
    &gresc   &kp N1 &kp N2 &kp N3 &kp N4 &kp N5 &kp N6 &kp N7 &kp N8 &kp N9 &kp N0 &kp MINUS &kp EQUAL &kp BSLH &kp BSPC   &kp HOME
    &kp TAB    &kp Q  &kp W  &kp E  &kp R  &kp T  &kp Y  &kp U  &kp I  &kp O  &kp P  &kp LBKT  &kp RBKT  &kp BSLH          &kp PG_UP
    &kp CLCK    &kp A  &kp S  &kp D  &kp F  &kp G  &kp H  &kp J  &kp K  &kp L  &kp SEMI &kp SQT        &kp RET             &kp PG_DN
   &kp LSHFT &kp NUBS &kp Z  &kp X  &kp C  &kp V  &kp B  &kp N  &kp M  &kp COMMA &kp DOT &kp FSLH      &kp RSHIFT  &kp UP  &kp END
    &kp LCTRL &kp LGUI &kp LALT             &kp SPACE                       &kp RALT  &mo 1             &kp LEFT &kp DOWN &kp RIGHT
            >;
        };

        layer1 {
            bindings = <
    &trans  &kp F1    &kp F2    &kp F3  &kp F4   &kp F5  &kp F6  &kp F7  &kp F8   &kp F9   &kp F10  &kp F11 &kp F12  &trans  &kp DELETE      &kp PRINTSCREEN
    &trans  &mkp LCLK   &mmu    &mkp RCLK  &trans   &trans  &trans  &Device_USB  &UF_BT1  &UF_BT2  &UF_BT3   &trans  &trans  &trans          &kp SCROLLLOCK
    &trans  &mml         &mmd     &mmr      &trans  &trans  &trans  &trans  &trans   &trans   &kp C_PREV  &kp C_PLAY_PAUSE      &trans       &kp PAUSE_BREAK
    &trans &trans  &trans  &trans  &kp C_AL_CALC  &trans &UF_RESET &trans &kp C_MUTE  &kp C_VOL_DN  &kp C_VOL_UP  &kp C_NEXT  &trans  &kp PAGE_UP  &kp INSERT
    &trans  &trans   &trans                            &trans                                   &trans    &trans          &kp HOME  &kp PAGE_DOWN  &kp END
            >;
        };
        layer2 { status = "reserved"; };
        layer3 { status = "reserved"; };
        layer4 { status = "reserved"; };
        layer5 { status = "reserved"; };
        layer6 { status = "reserved"; };
        layer7 { status = "reserved"; };
    };
};
